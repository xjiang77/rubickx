          }
        ],
        "routes": [
          {
            "model": "chat-pro",
            "tenant": "t1"
          },
          {
            "model": "embed-small",
            "tenant": "t1"
          }
        ]
      },
      "expected": {
        "routes": [
          {
            "model": "chat-pro",
            "provider": "openai",
            "context_window": 128000,
            "tenant": "t1"
          },
          {
            "model": "embed-small",
            "provider": "local",
            "context_window": 8192,
