{
  "pattern_id": "gof.structural.flyweight",
  "cases": [
    {
      "id": "metadata_is_reused",
      "category": "nominal",
      "input": {
        "definitions": [
          {
            "model": "chat-pro",
            "provider": "openai",
            "context_window": 128000
          }
        ],
        "routes": [
          {
            "model": "chat-pro",
            "tenant": "t1"
          },
          {
            "model": "chat-pro",
            "tenant": "t2"
          }
        ]
      },
      "expected": {
        "routes": [
          {
            "model": "chat-pro",
            "provider": "openai",
            "context_window": 128000,
            "tenant": "t1"
          },
          {
            "model": "chat-pro",
            "provider": "openai",
            "context_window": 128000,
            "tenant": "t2"
          }
        ],
        "flyweight_count": 1,
        "reused": true
      }
    },
    {
      "id": "empty_factory",
      "category": "boundary",
      "input": {
        "definitions": [],
        "routes": []
      },
      "expected": {
        "routes": [],
        "flyweight_count": 0,
        "reused": false
      }
    },
    {
      "id": "conflicting_definition",
      "category": "failure",
      "input": {
        "definitions": [
          {
            "model": "chat-pro",
            "provider": "openai",
            "context_window": 128000
          },
          {
            "model": "chat-pro",
