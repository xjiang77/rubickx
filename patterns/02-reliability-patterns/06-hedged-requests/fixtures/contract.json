      "input": {
        "idempotent": true,
        "hedge_delay_ms": 20,
        "primary": {
          "latency_ms": 15,
          "result": "failure"
        },
        "hedge": {
          "latency_ms": 20,
          "result": "success"
        }
      },
      "expected": {
        "winner": "hedge",
        "completed_ms": 35,
        "attempts": 2,
        "cancelled": []
      }
    },
    {
      "id": "all_attempts_failed",
      "category": "failure",
      "input": {
        "idempotent": true,
        "hedge_delay_ms": 20,
        "primary": {
          "latency_ms": 15,
          "result": "failure"
        },
        "hedge": {
          "latency_ms": 25,
          "result": "failure"
        }
      },
      "expected_error": {
        "code": "all_attempts_failed"
      }
