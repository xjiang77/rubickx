{
  "pattern_id": "reliability.hedged-requests",
  "cases": [
    {
      "id": "hedge_wins_tail",
      "category": "nominal",
      "input": {
        "idempotent": true,
        "hedge_delay_ms": 20,
        "primary": {
          "latency_ms": 100,
          "result": "success"
        },
        "hedge": {
          "latency_ms": 30,
          "result": "success"
        }
      },
      "expected": {
        "winner": "hedge",
        "completed_ms": 50,
        "attempts": 2,
        "cancelled": [
          "primary"
        ]
      }
    },
    {
      "id": "primary_finishes_before_delay",
      "category": "boundary",
      "input": {
        "idempotent": true,
        "hedge_delay_ms": 20,
        "primary": {
          "latency_ms": 10,
          "result": "success"
        },
        "hedge": {
          "latency_ms": 1,
          "result": "success"
        }
      },
      "expected": {
        "winner": "primary",
        "completed_ms": 10,
        "attempts": 1,
        "cancelled": []
      }
    },
    {
      "id": "side_effect_is_rejected",
      "category": "failure",
      "input": {
        "idempotent": false,
        "hedge_delay_ms": 20,
        "primary": {
          "latency_ms": 100,
          "result": "success"
        },
        "hedge": {
          "latency_ms": 30,
          "result": "success"
        }
      },
      "expected_error": {
